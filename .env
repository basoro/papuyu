PORT=4000
JWT_SECRET=your-super-secret-key-change-in-production
DB_PATH=./data/papuyu.db
NODE_ENV=development

# Server IP (Digunakan untuk fallback nip.io dan API)
SERVER_IP=103.187.146.74

# URL API (Otomatis menyesuaikan dengan IP jika belum ada domain)
VITE_API_URL=http://103.187.146.74:4000

# -- KONFIGURASI TRAEFIK & HTTPS --
# Jika TRAEFIK_HTTPS_ENABLED=true, maka Traefik akan memaksa redirect ke HTTPS
# dan mencoba membuat sertifikat Let's Encrypt untuk DOMAIN Anda.
# Jika TRAEFIK_HTTPS_ENABLED=false, Papuyu berjalan di HTTP biasa (cocok untuk IP).
TRAEFIK_HTTPS_ENABLED=false

# Domain utama aplikasi (Wajib diisi jika TRAEFIK_HTTPS_ENABLED=true)
# DOMAIN=rshd.my.id

# -- INTERNAL VARIABLES (DIPROSES OTOMATIS OLEH DOCKER COMPOSE) --
# Jangan diubah. Variabel ini memetakan nilai boolean di atas menjadi konfigurasi spesifik Traefik.
TRAEFIK_ENTRYPOINT=${TRAEFIK_HTTPS_ENABLED:+websecure}
TRAEFIK_ENTRYPOINT=${TRAEFIK_ENTRYPOINT:-web}
TRAEFIK_CERTRESOLVER=${TRAEFIK_HTTPS_ENABLED:+myresolver}
FORCE_HTTPS_TO=${TRAEFIK_HTTPS_ENABLED:+websecure}
FORCE_HTTPS_SCHEME=${TRAEFIK_HTTPS_ENABLED:+https}
