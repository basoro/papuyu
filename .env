PORT=4000
JWT_SECRET=your-super-secret-key-change-in-production
DB_PATH=./data/papuyu.db
NODE_ENV=development

# Server IP (Digunakan untuk fallback nip.io dan API)
SERVER_IP=103.187.146.74

# Domain utama aplikasi (Biarkan kosong jika belum ada, maka akan menggunakan SERVER_IP.nip.io)
# DOMAIN=rshd.my.id

# Mode SSL/TLS (Pilih 'web' untuk instalasi awal via IP, pilih 'websecure' jika sudah menggunakan DOMAIN asli)
TRAEFIK_ENTRYPOINT=web

# Aktifkan Let's Encrypt (Hanya gunakan 'myresolver' jika TRAEFIK_ENTRYPOINT=websecure dan DOMAIN sudah diset)
# TRAEFIK_CERTRESOLVER=myresolver

# Aktifkan paksaan redirect HTTP ke HTTPS (Kosongkan jika ingin false, isi 'true' jika sudah pakai HTTPS)
FORCE_HTTPS=

# URL API (Otomatis menyesuaikan dengan IP jika belum ada domain)
VITE_API_URL=http://103.187.146.74:4000

# -- KONFIGURASI INTERNAL (JANGAN DIUBAH KECUALI ANDA PAHAM) --
# Variabel di bawah ini digunakan oleh docker-compose untuk mengontrol redirect HTTP ke HTTPS
# secara dinamis berdasarkan nilai FORCE_HTTPS di atas.
FORCE_HTTPS_TO=${FORCE_HTTPS:+websecure}
FORCE_HTTPS_SCHEME=${FORCE_HTTPS:+https}
