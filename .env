PORT=4000
JWT_SECRET=your-super-secret-key-change-in-production
DB_PATH=./data/papuyu.db
NODE_ENV=development

# Server IP (Digunakan untuk fallback nip.io lokal jika domain belum dipakai)
SERVER_IP=103.188.171.242

# URL API untuk frontend
VITE_API_URL=https://api.rshd.my.id

# -- KONFIGURASI TRAEFIK & HTTPS --
# Jika TRAEFIK_HTTPS_ENABLED=true, maka Traefik akan memaksa redirect ke HTTPS
# dan mencoba membuat sertifikat Let's Encrypt untuk DOMAIN Anda.
# Jika TRAEFIK_HTTPS_ENABLED=false, Papuyu berjalan di HTTP biasa (cocok untuk IP).
TRAEFIK_HTTPS_ENABLED=true

# Domain utama aplikasi (Wajib diisi jika TRAEFIK_HTTPS_ENABLED=true)
DOMAIN=rshd.my.id

# Domain tambahan untuk pilihan pembuatan project (opsional)
# pisahkan dengan koma jika lebih dari satu
ADDITIONAL_DOMAINS=mlite.id,puskesmas.online
